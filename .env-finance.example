SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
# Price providers — set at least one. With both, Finnhub serves the regular session and
# Tiingo serves pre-market/after-hours (real extended-hours prices). With only one set,
# that provider serves every session.
FINNHUB_API_KEY=
TIINGO_API_KEY=
DATABASE_URL=postgres://portfolio:portfolio@postgres:5432/portfolio

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-password
GRAFANA_HOST_PORT=3300
SYNC_HOST_PORT=38080

SYNC_PUBLIC_URL=http://localhost:38080/sync
